{
  "expo": {
    "name": "Kinpath Family",
    "slug": "kinpath-family",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "kinpath-family",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#fdf4f0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "family.kinpath.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "920195f9-a8a8-4cdf-9b23-a402faf9b7ac"
      }
    }
  }
}
