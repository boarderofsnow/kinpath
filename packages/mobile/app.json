{
  "expo": {
    "name": "Kinpath Family",
    "slug": "kinpath-family",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icons/ios/icon.png",
    "scheme": "kinpath-family",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#fdf4f0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "family.kinpath.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/android/foreground.png",
        "backgroundColor": "#fdf4f0"
      },
      "package": "family.kinpath.app"
    },
    "web": {
      "favicon": "./assets/icons/web/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-apple-authentication",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "920195f9-a8a8-4cdf-9b23-a402faf9b7ac"
      }
    }
  }
}
