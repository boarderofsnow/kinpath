# ===========================================
# KinPath Environment Variables
# Copy this file to .env and fill in values
# ===========================================

# Supabase
# NEXT_PUBLIC_SUPABASE_ANON_KEY → use the Publishable key (sb_publishable_...)
# SUPABASE_SERVICE_ROLE_KEY     → use the Secret key (sb_secret_...)
# Found in: Supabase Dashboard → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# API package (Express server) — same values as above, different var names
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=sb_publishable_...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_FAMILY_PRICE_ID=price_...

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# RevenueCat
REVENUECAT_API_KEY=your-revenuecat-key
REVENUECAT_WEBHOOK_SECRET=your-webhook-secret

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...

# Email (Resend)
RESEND_API_KEY=re_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Mobile / Expo
EXPO_PUBLIC_SUPABASE_URL=http://localhost:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
EXPO_PUBLIC_API_URL=http://localhost:3001
